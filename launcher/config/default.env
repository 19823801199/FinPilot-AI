# FinPilot AI - Default Environment Variables
# This file is used when .env doesn't exist yet

# ============================================
# AI Services
# ============================================
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30
DEEPSEEK_MAX_RETRIES=3

# ============================================
# Application
# ============================================
APP_NAME=FinPilot AI
APP_VERSION=1.0.0
ENV=dev
DEBUG=true

# ============================================
# Ports
# ============================================
API_PORT=8000
WEB_PORT=3000

# ============================================
# Database
# ============================================
DATABASE_URL=sqlite+aiosqlite:///data/finpilot.db

# ============================================
# JWT
# ============================================
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Vector Database
# ============================================
CHROMA_HOST=localhost
CHROMA_PORT=8001
