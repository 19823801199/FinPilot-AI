# FinPilot AI - Global Environment Variables
# Copy this file to .env and fill in the values

# ==========================================
# AI Services
# ==========================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ==========================================
# Stock Data
# ==========================================
# AKShare does not require API key, but you can configure proxy if needed
AKSHARE_PROXY=

# ==========================================
# Database
# ==========================================
# SQLite (Development)
DATABASE_URL=sqlite+aiosqlite:///data/finpilot.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finpilot

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ==========================================
# Application
# ==========================================
APP_NAME=FinPilot AI
APP_VERSION=1.0.0
DEBUG=true

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# Vector Database (Reserved)
# ==========================================
CHROMA_HOST=localhost
CHROMA_PORT=8001
